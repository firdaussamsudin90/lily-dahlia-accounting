# Copy this file to .streamlit/secrets.toml for local development and fill in
# real values. NEVER commit the real secrets.toml — it's already in .gitignore.
#
# On Streamlit Community Cloud, don't upload this file: paste the same keys
# into the app's Settings -> Secrets box in the same TOML format instead.

# Supabase project -> Settings -> Database -> Connection string -> URI
# (use the "Session pooler" connection string, and set your DB password in it)
DATABASE_URL = "postgresql://postgres.xxxxxxxx:YOUR-PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

# Supabase project -> Settings -> API
SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY = "your-service_role-key-here"

# Any password you choose — this gates the whole app since it's on a public URL
APP_PASSWORD = "choose-a-password"
